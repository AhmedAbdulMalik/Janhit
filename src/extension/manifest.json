{
  "manifest_version": 3,
  "name": "Janhit - AI Civic Assistant",
  "version": "1.0.0",
  "description": "Voice-first civic assistant. Hold Ctrl + Space to speak.",
  "permissions": [
    "offscreen",
    "microphone",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/ptt.js"]
    }
  ]
}